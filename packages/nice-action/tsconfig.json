{
  "compilerOptions": {
    "lib": [
      "ESNext"
    ],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": [
      "bun",
      "vitest/globals"
    ],
    "paths": {
      "@nice-code/error": [
        "../nice-error/src/index.ts"
      ],
      "@nice-code/common-errors": [
        "../common-errors/src/index.ts"
      ],
      "#test/*": [
        "./src/test/*"
      ]
    }
  },
  "exclude": [
    "./build/**/*"
    // "./src/test/**/*",
    // "./src/react-query/**/*"
  ],
}