---
import Default from "@astrojs/starlight/components/Footer.astro";
---
<Default><slot /></Default>
<div class="nc-footer">
  <div class="nc-footer__inner">
    <div class="nc-footer__brand">
      <span class="nc-footer__mark">nc</span>
      <span class="nc-footer__name">nice-code</span>
    </div>
    <div class="nc-footer__meta">
      <span>MIT License</span>
      <span class="nc-footer__dot">·</span>
      <a href="https://github.com/lostpebble/nice-code" target="_blank" rel="noreferrer">GitHub</a>
      <span class="nc-footer__dot">·</span>
      <a href="https://www.npmjs.com/package/@nice-code/error" target="_blank" rel="noreferrer">npm</a>
    </div>
    <div class="nc-footer__ver">
      <span>typed errors · typed actions · pure TS</span>
    </div>
  </div>
</div>

<style>
  .nc-footer {
    border-top: 1px solid var(--nc-line-soft);
    margin-top: 2rem;
    padding: 1.5rem 0 0;
    font-family: var(--sl-font);
  }
  .nc-footer__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.25rem;
    font-size: 0.78rem;
    color: var(--nc-fg-3);
  }
  .nc-footer__brand {
    display: flex; align-items: center; gap: 0.55rem;
  }
  .nc-footer__mark {
    font-family: var(--sl-font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--nc-accent-ink);
    background: var(--sl-color-accent);
    padding: 3px 5px;
    border-radius: 3px;
    line-height: 1;
  }
  .nc-footer__name {
    font-family: var(--sl-font-display);
    font-size: 1rem;
    color: var(--nc-fg-2);
  }
  .nc-footer__meta {
    justify-self: center;
    display: flex; align-items: center; gap: 0.6rem;
  }
  .nc-footer__meta a {
    color: var(--nc-fg-2);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .nc-footer__meta a:hover {
    color: var(--sl-color-accent);
    border-bottom-color: var(--sl-color-accent);
  }
  .nc-footer__dot { color: var(--nc-fg-3); opacity: 0.6; }
  .nc-footer__ver {
    justify-self: end;
    font-family: var(--sl-font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--nc-fg-3);
  }
  @media (max-width: 720px) {
    .nc-footer__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .nc-footer__meta, .nc-footer__ver, .nc-footer__brand {
      justify-self: center;
    }
  }
</style>
