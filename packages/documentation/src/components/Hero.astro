---
import type { Props } from "@astrojs/starlight/props";

const { entry } = Astro.props;
if (!entry?.data) return;
const data = entry.data;
const hero = data.hero;

// Fallbacks if frontmatter doesn't supply a hero
const tagline =
  hero?.tagline ?? data.description ?? "Typed, serializable errors and actions for TypeScript.";
const title = hero?.title ?? data.title ?? "nice-code";
const actions = hero?.actions ?? [];
---

<div class="nc-hero">
  <div class="nc-hero__grid">
    <div class="nc-hero__left">
      <div class="nc-hero__eyebrow">
        <span class="nc-hero__dot"></span>
        <span>v2.0 · released Apr 2026</span>
      </div>

      <h1 class="nc-hero__title">
        Errors and actions<br/>
        <span class="nc-hero__italic">that travel well.</span>
      </h1>

      <p class="nc-hero__tagline" set:html={tagline}></p>

      {actions.length > 0 && (
        <div class="nc-hero__actions">
          {actions.map((a: any) => (
            <a
              href={a.link}
              class={`nc-hero__btn nc-hero__btn--${a.variant ?? "secondary"}`}
            >
              {a.text}
              {a.variant === "primary" && <span class="nc-hero__arrow">→</span>}
            </a>
          ))}
        </div>
      )}

      <dl class="nc-hero__stats">
        <div><dt>bundle</dt><dd>3.1<span>kb</span></dd></div>
        <div><dt>deps</dt><dd>0</dd></div>
        <div><dt>types</dt><dd>100<span>%</span></dd></div>
        <div><dt>runtime</dt><dd>any</dd></div>
      </dl>
    </div>

    <div class="nc-hero__right">
      <div class="nc-hero__code">
        <div class="nc-hero__code-chrome">
          <span class="nc-hero__tab is-active">auth.ts</span>
          <span class="nc-hero__tab">server.ts</span>
          <span class="nc-hero__tab">client.ts</span>
        </div>
        <pre><code><span class="tk-c">// Declare a domain of typed errors</span>
<span class="tk-k">import</span> <span class="tk-p">&#123;</span> <span class="tk-v">NiceError</span> <span class="tk-p">&#125;</span> <span class="tk-k">from</span> <span class="tk-s">"@nice-code/error"</span>

<span class="tk-k">export const</span> <span class="tk-v">AuthError</span> = <span class="tk-v">NiceError</span>.<span class="tk-f">domain</span>(<span class="tk-s">"auth"</span>, <span class="tk-p">&#123;</span>
  <span class="tk-v">NotSignedIn</span>:    <span class="tk-p">&#123;</span> <span class="tk-v">status</span>: <span class="tk-n">401</span> <span class="tk-p">&#125;</span>,
  <span class="tk-v">SessionExpired</span>: <span class="tk-p">&#123;</span> <span class="tk-v">status</span>: <span class="tk-n">401</span>, <span class="tk-v">renew</span>: <span class="tk-n">true</span> <span class="tk-p">&#125;</span>,
  <span class="tk-v">Forbidden</span>:      <span class="tk-p">&#123;</span> <span class="tk-v">status</span>: <span class="tk-n">403</span>, <span class="tk-v">scope</span>: <span class="tk-s">""</span> <span class="tk-p">&#125;</span>,
<span class="tk-p">&#125;</span>)

<span class="tk-c">// Throw — with full type inference on payload</span>
<span class="tk-k">throw new</span> <span class="tk-v">AuthError</span>.<span class="tk-v">Forbidden</span>(<span class="tk-p">&#123;</span> <span class="tk-v">scope</span>: <span class="tk-s">"billing.write"</span> <span class="tk-p">&#125;</span>)</code></pre>
      </div>
    </div>
  </div>
</div>

<style is:global>
  .nc-hero {
    padding: 3rem 0 4.5rem;
    max-width: 72rem;
    margin-inline: auto;
  }
  .nc-hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 1.4fr;
    gap: 3rem;
    align-items: center;
  }
  @media (max-width: 960px) {
    .nc-hero__grid { grid-template-columns: 1fr; gap: 2rem; }
  }

  .nc-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--sl-font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--nc-fg-3);
    border: 1px solid var(--nc-line);
    border-radius: 999px;
    padding: 4px 12px;
    margin-bottom: 1.4rem;
  }
  .nc-hero__dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--sl-color-accent);
    box-shadow: 0 0 10px var(--sl-color-accent);
  }

  .nc-hero__title {
    font-family: var(--sl-font-display);
    font-weight: 400;
    font-size: clamp(2.8rem, 5.2vw, 4.4rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--nc-fg-0);
    margin: 0 0 1.1rem;
  }
  .nc-hero__italic {
    font-style: italic;
    color: var(--sl-color-accent);
  }

  .nc-hero__tagline {
    font-size: 1.02rem;
    line-height: 1.55;
    color: var(--nc-fg-2);
    max-width: 32ch;
    margin: 0 0 1.8rem;
  }

  .nc-hero__actions {
    display: flex; flex-wrap: wrap; gap: 0.7rem;
    margin-bottom: 2.2rem;
  }
  .nc-hero__btn {
    display: inline-flex; align-items: center; gap: 0.55rem;
    font-family: var(--sl-font);
    font-weight: 500;
    font-size: 0.88rem;
    padding: 0.65rem 1.05rem;
    border-radius: 8px;
    text-decoration: none !important;
    border: 1px solid transparent;
    transition: all 150ms ease;
  }
  .nc-hero__btn--primary {
    background: var(--sl-color-accent);
    color: var(--nc-accent-ink) !important;
    border-color: var(--sl-color-accent);
  }
  .nc-hero__btn--primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 24px -6px var(--nc-accent-dim);
  }
  .nc-hero__btn--secondary,
  .nc-hero__btn--minimal {
    background: oklch(100% 0 0 / 0.03);
    color: var(--nc-fg-0) !important;
    border-color: var(--nc-line);
  }
  .nc-hero__btn--secondary:hover,
  .nc-hero__btn--minimal:hover {
    border-color: var(--nc-line-shade);
    background: oklch(100% 0 0 / 0.06);
  }
  .nc-hero__arrow {
    font-family: var(--sl-font-mono);
    transition: transform 150ms ease;
  }
  .nc-hero__btn:hover .nc-hero__arrow { transform: translateX(3px); }

  .nc-hero__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    padding-top: 1.4rem;
    border-top: 1px solid var(--nc-line-soft);
    margin: 0;
    max-width: 24rem;
  }
  .nc-hero__stats > div {
    border-left: 1px solid var(--nc-line-soft);
    padding-left: 0.75rem;
  }
  .nc-hero__stats > div:first-child {
    border-left: 0;
    padding-left: 0;
  }
  .nc-hero__stats dt {
    font-family: var(--sl-font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--nc-fg-3);
    margin-bottom: 0.2rem;
  }
  .nc-hero__stats dd {
    font-family: var(--sl-font-display);
    font-size: 1.5rem;
    color: var(--nc-fg-0);
    margin: 0;
  }
  .nc-hero__stats dd span {
    font-family: var(--sl-font-mono);
    font-size: 0.68rem;
    color: var(--nc-fg-3);
    margin-left: 2px;
    vertical-align: 4px;
  }

  /* Code card */
  .nc-hero__code {
    background: oklch(11% 0.004 250);
    border: 1px solid var(--nc-line);
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 40px 90px -20px oklch(0% 0 0 / 0.55),
      0 0 0 1px oklch(100% 0 0 / 0.02) inset;
  }
  .nc-hero__code-chrome {
    display: flex;
    gap: 0;
    background: oklch(14% 0.005 250);
    border-bottom: 1px solid var(--nc-line-soft);
    padding: 0 0.5rem;
  }
  .nc-hero__tab {
    font-family: var(--sl-font-mono);
    font-size: 0.72rem;
    color: var(--nc-fg-3);
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid transparent;
  }
  .nc-hero__tab.is-active {
    color: var(--nc-fg-0);
    border-bottom-color: var(--sl-color-accent);
  }
  .nc-hero__code pre {
    margin: 0;
    padding: 1.2rem 1.4rem 1.6rem;
    font-family: var(--sl-font-mono);
    font-size: 0.78rem;
    line-height: 1.75;
    color: var(--nc-fg-0);
    overflow-x: auto;
  }
  .tk-c { color: oklch(48% 0.01 250); font-style: italic; }
  .tk-k { color: oklch(80% 0.1 310); }
  .tk-v { color: oklch(85% 0.1 220); }
  .tk-f { color: oklch(86% 0.18 125); }
  .tk-s { color: oklch(80% 0.12 60); }
  .tk-n { color: oklch(82% 0.12 40); }
  .tk-p { color: oklch(55% 0.01 250); }
</style>
